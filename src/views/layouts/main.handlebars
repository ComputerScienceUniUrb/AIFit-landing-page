<html lang="{{{i18n 'lang-tag'}}}">
  <head>
    <meta charset="utf-8" />

    <title>AIFit</title>

    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="color-scheme" content="light dark" />

    <link href="/css/style.css" rel="stylesheet" />

    <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />
    <link rel="icon" type="image/png" sizes="32x32" href="/favicon-32x32.png" />
    <link rel="icon" type="image/png" sizes="16x16" href="/favicon-16x16.png" />
    <link rel="manifest" href="/site.webmanifest" />
  </head>

  <body>
    <header
      id="main-header"
      class="sticky top-0 z-50 transition-opacity duration-300"
    >

      <div
        id="header-logo-container"
        class="flex justify-center max-w-4xl mx-auto px-4 py-2 bg-[#121212] transition-opacity duration-300"
      >
        <img
          src="/aifit_logo.png"
          alt="AIFit application logo"
          width="100"
          height="100"
        />
      </div>

      
      <div class="flex justify-end text-sm text-white mx-10 items-center gap-2">

  <a
    href="?lang=en"
    class="
      transition
      hover:text-[#FDD673]
      {{#if (eq currentLang 'en')}}
        text-[#FDD673] font-bold
      {{else}}
        text-white
      {{/if}}
    "
  >
    EN
  </a>

  <span>|</span>

  <a
    href="?lang=it"
    class="
      transition
      hover:text-[#FDD673]
      {{#if (eq currentLang 'it')}}
        text-[#FDD673] font-bold
      {{else}}
        text-white
      {{/if}}
    "
  >
    IT
  </a>

</div>

    </header>

    <main class="">
      {{{body}}}
    </main>

    <footer class="container">
      <p>
        <a href="https://digit.srl/privacy/aifit/" target="_blank">{{{i18n
            "privacy-policy"
          }}}</a><br />
        Università di Urbino&nbsp;“Carlo Bo” / DIGIT&nbsp;srl &mdash;&nbsp;{{year}}
      </p>
    </footer>

  </body>
</html>

{{! <script>

  const header = document.getElementById('main-header');
  window.addEventListener('scroll', () => { if (window.scrollY > 100) {
  header.classList.add('opacity-0', 'pointer-events-none'); } else {
  header.classList.remove('opacity-0', 'pointer-events-none'); } });
</script> }}

<script>
  const headerDiv = document.getElementById('header-logo-container');
  window.addEventListener('scroll', () => { if (window.scrollY > 50) {
  headerDiv.style.opacity = '0.9'; } else { headerDiv.style.opacity = '1'; } });
</script>
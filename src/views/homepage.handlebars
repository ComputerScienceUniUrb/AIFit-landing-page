<div class="max-w-4xl mx-auto px-4 py-8 text-gray-800 antialiased">
  <!-- Header / Hgroup -->
  <header class="mb-12 text-center md:text-left">
    <h1
      class="text-4xl md:text-5xl font-extrabold tracking-tight text-[#FDD673] mb-3"
    >
      AIFit
    </h1>

    <p
      class="text-lg md:text-xl text-white font-medium max-w-2xl leading-relaxed"
    >
      {{i18n "hero-subtitle"}}
    </p>
  </header>

  <!-- Sezione Introduzione -->
  <div
    class="space-y-6 text-base md:text-lg leading-relaxed text-[#C2C7D0] mb-12"
  >
    <p>
      <strong class="text-[#FDD673] font-semibold">AI Fit</strong>

      {{i18n "intro-p1"}}

      <a
        href="https://uniurb.it/"
        target="_blank"
        class="text-[#FDD673] hover:text-[#c8a857] underline transition duration-200"
      >
        {{i18n "intro-p1-link-text"}}
      </a>

      {{i18n "intro-p1-end"}}
    </p>

    <p>
      {{i18n "intro-p2"}}
    </p>
  </div>

  <!-- Nuovi Sviluppi -->
  <section class="p-6 md:p-8 mb-12 border-2 border-blue-100">
    <h2 class="text-2xl font-bold text-[#edb21d] mb-4">
      {{i18n "section-research-title"}}
    </h2>

    <p class="text-[#C2C7D0] mb-6 leading-relaxed">
      {{i18n "section-research-p1"}}

      <span class="font-semibold text-[#edb21d]">
        crowdsensing
      </span>

      {{i18n "section-research-p2"}}

      <span class="font-semibold text-[#edb21d]">
        crowdsourcing
      </span>

      {{i18n "section-research-p3"}}
    </p>

    <div class="grid md:grid-cols-2 gap-6">

      <div class="bg-white p-5 shadow-sm border border-gray-100">
        <h3 class="font-bold text-gray-900 mb-2 flex items-center">
          <span class="w-2 h-2 bg-[#edb21d] rounded-full mr-2"></span>

          {{i18n "card-movements-title"}}
        </h3>

        <p class="text-sm text-black leading-relaxed">
          {{i18n "card-movements-desc"}}
        </p>
      </div>

      <div class="bg-white p-5 shadow-sm border border-gray-100">
        <h3 class="font-bold text-gray-900 mb-2 flex items-center">
          <span class="w-2 h-2 bg-[#edb21d] rounded-full mr-2"></span>

          {{i18n "card-management-title"}}
        </h3>

        <p class="text-sm text-black leading-relaxed">
          {{i18n "card-management-desc"}}
        </p>
      </div>

    </div>
  </section>

  <!-- Sezione Come Funziona -->
  <section class="space-y-6 text-gray-700 mb-12">
    <h2 class="text-2xl font-bold text-[#C2C7D0] mb-2">
      {{i18n "section-how-title"}}
    </h2>

    <p class="leading-relaxed text-[#C2C7D0]">
      {{i18n "section-how-p1-start"}}

      <span class="font-medium text-white">
        QR Code
      </span>

      {{i18n "section-how-p1-end"}}
    </p>

    <p class="leading-relaxed text-[#C2C7D0]">
      {{i18n "section-how-p2"}}
    </p>

    <!-- WOM -->
    <div
      class="p-4 bg-amber-50 rounded-xl border border-amber-200 text-sm md:text-base text-amber-900 flex flex-col md:flex-row md:items-center justify-between gap-4"
    >
      <p class="leading-relaxed">
        {{i18n "wom-text-start"}}

        <a
          href="https://wom.social"
          target="_blank"
          rel="noopener noreferrer"
          class="font-bold underline hover:text-amber-950 transition duration-200"
        >
          WOM
        </a>

        {{i18n "wom-text-end"}}
      </p>
    </div>
  </section>

  <!-- Download -->
  <section class="pt-8 border-t border-gray-200 text-center md:text-left">
    <h2 class="text-2xl font-bold text-[#C2C7D0] mb-6">
      {{i18n "download-title"}}
    </h2>

    <p class="text-[#C2C7D0] mb-6">
      {{i18n "download-desc"}}
    </p>

    <div class="flex flex-wrap justify-center md:justify-start gap-4">

      <a
        href="https://apps.apple.com/us/app/aifit/id6744040583"
        class="transition transform hover:scale-105 duration-200"
        target="_blank"
        rel="noopener noreferrer"
      >
        <img
          src="/badge_app_store_{{currentLang}}.png"
          alt="{{i18n 'alt-app-store'}}"
          class="h-12 w-auto object-contain"
          width="503"
          height="168"
        />
      </a>

      <a
        href="https://play.google.com/store/apps/details?id=it.uniurb.aifit"
        class="transition transform hover:scale-105 duration-200"
        target="_blank"
        rel="noopener noreferrer"
      >
        <img
          src="/badge_google_play_{{currentLang}}.png"
          alt="{{i18n 'alt-google-play'}}"
          class="h-12 w-auto object-contain"
          width="564"
          height="168"
        />
      </a>

    </div>
  </section>
</div>